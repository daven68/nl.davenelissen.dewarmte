  "flow": {
    "triggers": [
      {
        "id": "pump_state_changed",
        "title": {
          "en": "The heat pump status changed",
          "nl": "De warmtepompstatus is gewijzigd"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "measure_target_temperature_changed",
        "title": {
          "en": "The target supply temperature changed",
          "nl": "De doelaanvoertemperatuur is gewijzigd"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "pump_is_on",
        "title": {
          "en": "The heat pump !{{is|isn't}} on",
          "nl": "De warmtepomp !{{is|is niet}} aan"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "target_supply_temperature_above",
        "title": {
          "en": "The target supply temperature is above a value",
          "nl": "De doelaanvoertemperatuur is hoger dan een waarde"
        },
        "titleFormatted": {
          "en": "The target supply temperature is !{{above|below}} [[temperature]] °C",
          "nl": "De doelaanvoertemperatuur is !{{hoger|lager}} dan [[temperature]] °C"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          },
          {
            "name": "temperature",
            "type": "number",
            "title": {
              "en": "Temperature (°C)",
              "nl": "Temperatuur (°C)"
            },
            "min": 0,
            "max": 100,
            "step": 0.1
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "DeWarmte Heat Pump",
        "nl": "DeWarmte Warmtepomp"
      },
      "class": "heatpump",
      "capabilities": [
        "pump_active",
        "measure_temperature",
        "measure_target_temperature",
        "pump_state",
        "alarm_generic"
      ],
      "capabilitiesOptions": {
        "pump_active": {
          "titleTrue": {
            "en": "On",
            "nl": "Aan"
          },
          "titleFalse": {
            "en": "Off",
            "nl": "Uit"
          }
        }
      },
      "images": {
        "small": "/drivers/dewarmte/assets/images/small.png",
        "large": "/drivers/dewarmte/assets/images/large.png",
        "xlarge": "/drivers/dewarmte/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "custom_login"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "dewarmte"
    }
  ],
  "capabilities": {
    "measure_target_temperature": {
      "type": "number",
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "units": {
        "en": "°C",
        "nl": "°C"
      },
      "decimals": 1,
      "title": {
        "en": "Target supply temperature",
        "nl": "Doelaanvoertemperatuur"
      }
    },
    "pump_active": {
      "type": "boolean",
      "title": {
        "en": "Heat pump active",
        "nl": "Warmtepomp actief"
      },
      "getable": true,
      "setable": false,
      "uiComponent": null,
      "uiQuickAction": false
    },
    "pump_state": {
      "type": "enum",
      "title": {
        "en": "Heat pump status",
        "nl": "Warmtepompstatus"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "values": [
        {
          "id": "on",
          "title": {
            "en": "On",
            "nl": "Aan"
          }
        },
        {
          "id": "off",
          "title": {
            "en": "Off",
            "nl": "Uit"
          }
        }
      ]
    }
  }
}