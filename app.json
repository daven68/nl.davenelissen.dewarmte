  "flow": {
    "triggers": [
      {
        "id": "pump_state_changed",
        "title": {
          "en": "The heat pump status changed",
          "nl": "De warmtepompstatus is gewijzigd"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "measure_target_temperature_changed",
        "title": {
          "en": "The target supply temperature changed",
          "nl": "De doelaanvoertemperatuur is gewijzigd"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "gas_boiler_active_true",
        "title": {
          "en": "The gas boiler became active",
          "nl": "De cv-ketel is actief geworden"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "gas_boiler_active_false",
        "title": {
          "en": "The gas boiler became inactive",
          "nl": "De cv-ketel is niet meer actief"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "thermostat_active_true",
        "title": {
          "en": "The thermostat became active",
          "nl": "De thermostaat is actief geworden"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "thermostat_active_false",
        "title": {
          "en": "The thermostat became inactive",
          "nl": "De thermostaat is niet meer actief"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "pump_is_on",
        "title": {
          "en": "The heat pump !{{is|isn't}} on",
          "nl": "De warmtepomp !{{is|is niet}} aan"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "target_supply_temperature_above",
        "title": {
          "en": "The target supply temperature is above a value",
          "nl": "De doelaanvoertemperatuur is hoger dan een waarde"
        },
        "titleFormatted": {
          "en": "The target supply temperature is !{{above|below}} [[temperature]] °C",
          "nl": "De doelaanvoertemperatuur is !{{hoger|lager}} dan [[temperature]] °C"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          },
          {
            "name": "temperature",
            "type": "number",
            "title": {
              "en": "Temperature (°C)",
              "nl": "Temperatuur (°C)"
            },
            "min": 0,
            "max": 100,
            "step": 0.1
          }
        ]
      },
      {
        "id": "gas_boiler_is_active",
        "title": {
          "en": "The gas boiler !{{is|isn't}} active",
          "nl": "De cv-ketel !{{is|is niet}} actief"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      },
      {
        "id": "thermostat_is_active",
        "title": {
          "en": "The thermostat !{{is|isn't}} active",
          "nl": "De thermostaat !{{is|is niet}} actief"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=dewarmte"
          }
        ]
      }
    ]
  },
